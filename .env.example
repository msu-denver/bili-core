# ============================================================================
# BiliCore — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically to inject these as container
# environment variables. Never commit .env to git (it's in .gitignore).
# ============================================================================

# ============================================================================
# Google Cloud
# ============================================================================

GOOGLE_APPLICATION_CREDENTIALS=/root/.google/credentials.json
GOOGLE_PROJECT_ID=YOUR_PROJECT_ID
# Create by running: base64 -i env/bili_root/.google/credentials.json
GOOGLE_CREDENTIALS=BASE64_ENCODED_KEY

# ============================================================================
# LLM Providers (configure the ones you use)
# ============================================================================

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/

# OpenAI
OPENAI_API_KEY=your-api-key

# ============================================================================
# Search & Knowledge
# ============================================================================

OPENSEARCH_URL=http://bilicore-dev.us-east-1.opensearch.localhost.localstack.cloud:4566
DEFAULT_PROMPT_PATH=./bili/prompts/default_prompts.json

# ============================================================================
# Weather APIs
# ============================================================================

# OpenWeatherMap — https://home.openweathermap.org/
OPENWEATHERMAP_API_KEY=KEY

# WeatherAPI — https://www.weatherapi.com/
WEATHER_API_KEY=KEY
FREE_WEATHER_API=http://api.weatherapi.com/v1/current.json?key=

# ============================================================================
# Web Search
# ============================================================================

# SerpApi — https://serpapi.com/dashboard
SERP_API_KEY=KEY

# ============================================================================
# Database Connections
# ============================================================================

# PostgreSQL (state management checkpointer)
POSTGRES_CONNECTION_STRING=postgresql://bilicore:bilicore@bili-core-postgis:5432/

# MongoDB (alternative checkpointer)
MONGO_CONNECTION_STRING=mongodb://bilicore:bilicore@bili-core-mongodb:27017/

# ============================================================================
# Authentication
# ============================================================================

JWT_SECRET_KEY=super-secret-key

# SQLite profile database path (inside container)
PROFILE_DB_PATH=/root/.bili/profile.db
